RewriteEngine On

# Permite o acesso direto a arquivos estïŋ―ïŋ―ïŋ―ticos dentro de 'public'
RewriteRule ^assets/ - [L]
RewriteRule ^img/ - [L]
RewriteRule ^js/ - [L]

# Certifica-se de que o redirecionamento da raiz da URL para o 'index.php' funciona corretamente
RewriteRule ^$ index.php [L]

# Redireciona todas as outras requisiïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―es para index.php
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ index.php?action=$1 [QSA,L]